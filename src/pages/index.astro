---
import { format } from "date-fns";
import { fr } from "date-fns/locale";
import MapPanel from "../components/MapPanel.astro";
import {
  clubInfo,
  faqItems,
  getHomeAnnouncements,
  homeHighlights,
  trainingSchedule,
} from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const heroMeta = [
  clubInfo.city,
  "Lundi au vendredi 18h00 - 20h00",
  "Samedi 10h00 - 11h00",
];

const homeAnnouncements = getHomeAnnouncements();

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SportsClub",
      "@id": `${clubInfo.siteUrl}#club`,
      name: clubInfo.name,
      description:
        "Club de boxe anglaise à La Louvière pour débutants, pratiquants loisir et compétiteurs. Encadrement structuré, cours du soir et progression suivie.",
      url: clubInfo.siteUrl,
      image: `${clubInfo.siteUrl}/hero-boxe.jpg`,
      email: clubInfo.email,
      telephone: clubInfo.phoneHref,
      address: {
        "@type": "PostalAddress",
        streetAddress: clubInfo.addressLine,
        addressLocality: clubInfo.city,
        addressRegion: clubInfo.region,
        postalCode: clubInfo.postalCode,
        addressCountry: clubInfo.countryCode,
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: clubInfo.latitude,
        longitude: clubInfo.longitude,
      },
      sport: "Boxing",
      hasMap: clubInfo.googleMapsUrl,
      sameAs: clubInfo.socialLinks.map((link) => link.href),
      areaServed: clubInfo.areaServed.map((area) => ({
        "@type": "Place",
        name: area,
      })),
      openingHoursSpecification: trainingSchedule.map((slot) => ({
        "@type": "OpeningHoursSpecification",
        dayOfWeek: `https://schema.org/${slot.schemaDay}`,
        opens: slot.schemaDay === "Saturday" ? "10:00" : "18:00",
        closes: slot.schemaDay === "Saturday" ? "11:00" : "20:00",
      })),
    },
    {
      "@type": "FAQPage",
      "@id": `${clubInfo.siteUrl}#faq`,
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    },
  ],
};

const schema = JSON.stringify(localBusinessSchema);
---

<BaseLayout
  title={`Club de boxe anglaise à ${clubInfo.city} | ${clubInfo.name}`}
  description={`Club de boxe anglaise à ${clubInfo.city} pour débutants, loisir et compétiteurs. Cours du soir, séance d'essai et encadrement structuré.`}
  image="/hero-boxe.jpg"
  schema={schema}
>
  <section class="hero">
    <div class="hero-decor-line"></div>
    <div class="hero-bg-name">COLAK</div>

    <div class="container">
      <div class="hero-shell">
        <div class="hero-main">
          <div class="hero-badge">
            <span class="line"></span>
            <span>BOXE ANGLAISE • {clubInfo.city.toUpperCase()}</span>
          </div>

          <h1 class="hero-title">
            <span>BOXING CLUB</span><br />
            <span class="text-stroke">COLAK</span>
          </h1>

          <p class="hero-lead">
            Débutants, loisir sérieux et compétition dans un cadre net, suivi et respecté.
          </p>

          <div class="hero-actions">
            <a href="/contact?sujet=essai" class="btn-main">SÉANCE D'ESSAI</a>
            <a href="#annonces" class="btn-secondary-link">VOIR LES ANNONCES</a>
          </div>

          <ul class="hero-meta">
            {heroMeta.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-intro">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-title-wrap">
          <span class="section-kicker">Le bon cadre</span>
          <h2 class="title-premium">
            Apprendre, reprendre ou pousser plus loin la boxe anglaise à {clubInfo.city}.
          </h2>
        </div>

        <div class="text-premium">
          <p>Technique, discipline, régularité. Le club s'adresse aux profils qui veulent progresser proprement.</p>
        </div>
      </div>

      <div class="highlights-grid">
        {homeHighlights.map((item) => (
          <article class="highlight-card reveal">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {homeAnnouncements.length > 0 && (
    <section class="section-news alt" id="annonces">
      <div class="container">
        <div class="header-flex">
          <h2 class="section-title-small">Annonces du club</h2>
          <div class="line"></div>
        </div>

        <div class="news-track">
          {homeAnnouncements.map((item) => (
            <article class={`news-card ${item.urgent ? "is-urgent" : ""} ${item.image ? "has-image" : ""}`}>
              {item.image && (
                <div class="news-media">
                  <img
                    src={item.image}
                    alt={item.imageAlt ?? item.title}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}

              <div class="news-content">
                <div class="news-meta">
                  <span class="news-category">{item.category}</span>
                  {item.urgent && <span class="badge-urgent">Prioritaire</span>}
                </div>

                <time class="news-date" datetime={item.date}>
                  {format(new Date(item.date), "dd MMM yyyy", { locale: fr })}
                </time>

                <h3>{item.title}</h3>
                <p>{item.excerpt}</p>

                {item.details && (
                  <ul class="news-pills">
                    {item.details.map((detail) => <li>{detail}</li>)}
                  </ul>
                )}

                <a href={item.link.href} class="news-link">{item.link.label}</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section-schedule" id="horaires">
    <div class="container">
      <div class="schedule-header">
        <div>
          <span class="section-kicker">Organisation</span>
          <h2 class="section-title-center">Planning d'entraînement</h2>
        </div>
        <p class="schedule-copy"></p>
      </div>

      <div class="schedule-list">
        {trainingSchedule.map((slot) => (
          <div class="schedule-item">
            <div class="item-day">{slot.day}</div>
            <div class="item-content">
              <span class="item-type">{slot.audience}</span>
              <span class="item-time">{slot.time}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-faq" id="faq">
    <div class="container">
      <div class="faq-header">
        <span class="section-kicker">Questions fréquentes</span>
        <h2 class="title-premium">Avant de venir</h2>
      </div>

      <div class="faq-list">
        {faqItems.map((item) => (
          <details class="faq-item reveal">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section-contact">
    <div class="container">
      <MapPanel
        title="Un club accessible depuis toute la région du Centre"
        subtitle={`Le ${clubInfo.name} est basé à ${clubInfo.city}. Accès simple, planning clair, contact direct.`}
        detailsTitle="Pratique locale"
      />
    </div>
  </section>

  <script is:inline>
    document.documentElement.classList.add("reveal-ready");

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".reveal").forEach((element) => observer.observe(element));
  </script>

  <style>
    .hero {
      position: relative;
      overflow: hidden;
      padding: 136px 0 70px;
      background:
        radial-gradient(circle at top right, rgba(199, 157, 49, 0.16), transparent 28rem),
        #000;
    }

    .hero-decor-line {
      position: absolute;
      left: 5%;
      top: 0;
      bottom: 0;
      width: 1px;
      background: rgba(199, 157, 49, 0.1);
      z-index: 1;
    }

    .hero-bg-name {
      position: absolute;
      right: -4vw;
      bottom: 2vh;
      font-family: var(--font-accent);
      font-size: 22vw;
      color: rgba(255, 255, 255, 0.03);
      line-height: 0.8;
      z-index: 0;
      pointer-events: none;
    }

    .hero-shell {
      position: relative;
      z-index: 1;
      max-width: 1120px;
    }

    .hero-badge {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      color: var(--color-accent);
      font-family: var(--font-accent);
      font-size: 0.92rem;
      letter-spacing: 0.22em;
    }

    .hero-badge .line {
      width: 40px;
      height: 1px;
      background: var(--color-accent);
    }

    .hero-title {
      font-size: clamp(4rem, 10vw, 7.6rem);
      margin-bottom: 18px;
    }

    .hero-lead {
      max-width: 42rem;
      color: #c2c2c2;
      font-size: clamp(1rem, 1.7vw, 1.15rem);
      line-height: 1.6;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px 22px;
      margin-top: 24px;
    }

    .btn-main {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 56px;
      padding: 0 28px;
      background: var(--color-accent);
      color: #050505;
      font-family: var(--font-accent);
      font-size: 1.12rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      box-shadow: 0 18px 40px rgba(199, 157, 49, 0.22);
    }

    .btn-secondary-link {
      font-family: var(--font-accent);
      font-size: 1rem;
      letter-spacing: 0.08em;
      color: #fff;
      border-bottom: 1px solid var(--color-accent);
      padding-bottom: 4px;
      opacity: 0.85;
    }

    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 18px;
      margin-top: 20px;
    }

    .hero-meta li {
      position: relative;
      color: #d8d8d8;
      font-size: 0.95rem;
      line-height: 1.4;
      white-space: nowrap;
    }

    .hero-meta li:not(:last-child)::after {
      content: "";
      position: absolute;
      right: -10px;
      top: 50%;
      width: 3px;
      height: 3px;
      border-radius: 999px;
      background: rgba(199, 157, 49, 0.7);
      transform: translateY(-50%);
    }

    .section-intro,
    .section-news,
    .section-schedule,
    .section-faq,
    .section-contact {
      padding: 78px 0;
    }

    .section-news.alt {
      background: rgba(255, 255, 255, 0.015);
    }

    .section-kicker {
      display: inline-flex;
      margin-bottom: 14px;
      color: var(--color-accent);
      font-family: var(--font-accent);
      font-size: 0.9rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .intro-grid,
    .schedule-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.95fr);
      gap: 28px;
      align-items: start;
    }

    .title-premium,
    .section-title-center {
      font-size: clamp(2.1rem, 4.8vw, 3.2rem);
      color: #fff;
      line-height: 1.05;
    }

    .text-premium,
    .schedule-copy {
      color: #b3b3b3;
      font-size: 1.02rem;
      line-height: 1.62;
    }

    .highlights-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
      margin-top: 34px;
    }

    .highlight-card {
      padding: 24px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(255, 255, 255, 0.025);
    }

    .highlight-card h3 {
      margin-bottom: 10px;
      color: #fff;
      font-size: 1.3rem;
    }

    .highlight-card p {
      color: #9d9d9d;
      line-height: 1.55;
    }

    .header-flex {
      display: flex;
      align-items: end;
      gap: 20px;
    }

    .section-title-small {
      font-size: 1.15rem;
      color: var(--color-accent);
      letter-spacing: 0.22em;
    }

    .header-flex .line {
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, 0.07);
      margin-bottom: 6px;
    }

    .news-track {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(340px, 410px);
      gap: 16px;
      margin-top: 28px;
      overflow-x: auto;
      overscroll-behavior-x: contain;
      scroll-snap-type: x mandatory;
      padding-bottom: 8px;
      scrollbar-width: thin;
      scrollbar-color: rgba(199, 157, 49, 0.5) rgba(255, 255, 255, 0.04);
    }

    .news-track::-webkit-scrollbar {
      height: 8px;
    }

    .news-track::-webkit-scrollbar-thumb {
      background: rgba(199, 157, 49, 0.5);
      border-radius: 999px;
    }

    .news-card {
      display: flex;
      flex-direction: column;
      min-height: 100%;
      border: 1px solid rgba(199, 157, 49, 0.12);
      background: rgba(255, 255, 255, 0.025);
      overflow: hidden;
      scroll-snap-align: start;
    }

    .news-card.has-image {
      display: grid;
      grid-template-columns: 140px minmax(0, 1fr);
      align-items: stretch;
    }

    .news-card.is-urgent {
      border-color: rgba(199, 157, 49, 0.28);
      background: linear-gradient(180deg, rgba(199, 157, 49, 0.08), rgba(255, 255, 255, 0.02));
    }

    .news-media {
      min-height: 100%;
    }

    .news-media img {
      width: 100%;
      height: 100%;
      aspect-ratio: auto;
      object-fit: cover;
    }

    .news-content {
      display: flex;
      flex-direction: column;
      min-height: 100%;
      padding: 14px 16px;
    }

    .news-meta {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 12px;
    }

    .news-category,
    .badge-urgent {
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      padding: 0 10px;
      font-family: var(--font-accent);
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .news-category {
      color: var(--color-accent);
      background: rgba(199, 157, 49, 0.08);
    }

    .badge-urgent {
      background: var(--color-accent);
      color: #050505;
    }

    .news-date {
      margin-bottom: 10px;
      color: #d4d4d4;
      font-size: 0.84rem;
    }

    .news-card h3 {
      margin-bottom: 8px;
      color: #fff;
      font-size: 1.16rem;
      line-height: 1.08;
    }

    .news-card p {
      color: #b8b8b8;
      line-height: 1.55;
      font-size: 0.9rem;
    }

    .news-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .news-pills li {
      padding: 7px 10px;
      border: 1px solid rgba(199, 157, 49, 0.2);
      background: rgba(199, 157, 49, 0.08);
      color: #fff;
      font-size: 0.84rem;
    }

    .news-link {
      margin-top: auto;
      padding-top: 14px;
      color: #fff;
      font-family: var(--font-accent);
      font-size: 0.95rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .news-link:hover {
      color: var(--color-accent);
    }

    .schedule-header {
      margin-bottom: 20px;
    }

    .schedule-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .schedule-item {
      display: grid;
      gap: 10px;
      align-content: start;
      min-height: 132px;
      padding: 18px;
      border-top: 2px solid var(--color-accent);
      background: rgba(255, 255, 255, 0.03);
      border-right: 1px solid rgba(255, 255, 255, 0.04);
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      border-left: 1px solid rgba(255, 255, 255, 0.04);
    }

    .item-day {
      width: auto;
      color: var(--color-accent);
      font-family: var(--font-accent);
      font-size: 1.5rem;
      letter-spacing: 0.05em;
      line-height: 1;
    }

    .item-content {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .item-type {
      color: #fff;
      font-size: 0.92rem;
      font-weight: 700;
      line-height: 1.45;
    }

    .item-time {
      color: #d8d8d8;
      font-size: 1rem;
      font-family: var(--font-accent);
      letter-spacing: 0.08em;
    }

    .faq-header {
      display: flex;
      flex-direction: column;
      align-items: start;
      gap: 6px;
      margin-bottom: 24px;
    }

    .faq-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .faq-item {
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(255, 255, 255, 0.025);
    }

    .faq-item summary {
      list-style: none;
      cursor: pointer;
      padding: 18px 20px;
      color: #fff;
      font-family: var(--font-accent);
      font-size: 1.2rem;
      letter-spacing: 0.04em;
    }

    .faq-item summary::-webkit-details-marker {
      display: none;
    }

    .faq-item p {
      padding: 0 20px 18px;
      color: #a9a9a9;
      line-height: 1.55;
    }

    .faq-item[open] {
      border-color: rgba(199, 157, 49, 0.18);
    }

    .reveal {
      opacity: 1;
      transform: none;
    }

    :global(html.reveal-ready) .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    :global(html.reveal-ready) .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (max-width: 1080px) {
      .intro-grid,
      .schedule-header {
        grid-template-columns: 1fr;
      }

      .schedule-list {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .faq-list {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .highlights-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 820px) {
      .hero {
        padding-top: 116px;
      }

      .hero-bg-name,
      .hero-decor-line {
        display: none;
      }

      .highlights-grid {
        grid-template-columns: 1fr;
      }

      .faq-list {
        grid-template-columns: 1fr;
      }

      .header-flex {
        flex-direction: column;
        align-items: start;
        gap: 12px;
      }

      .header-flex .line {
        width: 100%;
      }

      .news-track {
        grid-auto-columns: minmax(320px, 76vw);
      }

      .news-card.has-image {
        grid-template-columns: 130px minmax(0, 1fr);
      }
    }

    @media (max-width: 640px) {
      .hero {
        padding: 108px 0 62px;
      }

      .hero-title {
        font-size: 3.25rem;
      }

      .hero-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .btn-main {
        width: 100%;
      }

      .hero-shell {
        max-width: none;
      }

      .highlight-card {
        padding: 16px;
      }

      .section-intro,
      .section-news,
      .section-schedule,
      .section-faq,
      .section-contact {
        padding: 64px 0;
      }

      .news-track {
        grid-auto-columns: minmax(84vw, 84vw);
      }

      .schedule-list {
        grid-template-columns: 1fr;
      }

      .schedule-item {
        min-height: auto;
        padding: 16px;
      }

      .hero-meta {
        gap: 8px;
      }

      .hero-meta li {
        white-space: normal;
      }

      .hero-meta li::after {
        display: none;
      }

      .news-card.has-image {
        grid-template-columns: 1fr;
      }

      .news-pills {
        flex-direction: column;
      }

      .faq-item summary {
        font-size: 1.05rem;
      }
    }
  </style>
</BaseLayout>
