---
import { clubInfo } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const legalSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "PrivacyPolicy",
  name: `Politique de confidentialité | ${clubInfo.name}`,
  url: `${clubInfo.siteUrl}/politique-de-confidentialite`,
});
---

<BaseLayout
  title={`Politique de confidentialité | ${clubInfo.name}`}
  description={`Informations sur la gestion des données personnelles sur le site du ${clubInfo.name}.`}
  schema={legalSchema}
>
  <section class="legal-section">
    <div class="container narrow">
      <div class="reveal">
        <span class="section-label">Cadre légal</span>
        <h1 class="section-title">Politique de <span class="text-stroke">confidentialité</span></h1>

        <div class="legal-content">
          <p class="last-update">Dernière mise à jour : 14 mars 2026</p>

          <p class="intro">
            Cette page résume les données traitées sur le site du <strong>{clubInfo.name}</strong>,
            l'usage du formulaire de contact, les contenus tiers et les préférences de confidentialité.
          </p>

          <div class="legal-grid">
            <article class="legal-card">
              <h2>1. Responsable</h2>
              <p>
                Le responsable du traitement est le <strong>{clubInfo.name}</strong>,
                {` `}situé à <strong>{clubInfo.addressFull}</strong>.
                Pour toute question : <strong class="gold">{clubInfo.email}</strong>.
              </p>
            </article>

            <article class="legal-card">
              <h2>2. Données traitées</h2>
              <ul class="legal-list">
                <li>
                  <strong>Formulaire de contact :</strong> nom, email, sujet et message.
                </li>
                <li>
                  <strong>Mesure d'audience :</strong> données techniques agrégées via Vercel Web Analytics.
                </li>
                <li>
                  <strong>Préférences :</strong> mémorisation locale de votre choix de confidentialité dans le navigateur.
                </li>
              </ul>
            </article>

            <article class="legal-card">
              <h2>3. Finalités</h2>
              <ul class="legal-list">
                <li>Répondre aux demandes envoyées via le formulaire.</li>
                <li>Améliorer la lisibilité et les performances du site.</li>
                <li>Éviter de reposer votre choix de confidentialité à chaque visite.</li>
              </ul>
            </article>

            <article class="legal-card">
              <h2>4. Services utilisés</h2>
              <ul class="legal-list">
                <li>
                  <strong>EmailJS :</strong> utilisé pour transmettre les messages du formulaire.
                </li>
                <li>
                  <strong>Vercel Web Analytics :</strong> utilisé pour mesurer l'audience du site sans cookie analytique.
                </li>
                <li>
                  <strong>Liens Google Maps / Waze :</strong> ces services externes ne s'ouvrent que si vous cliquez sur les boutons prévus à cet effet.
                </li>
              </ul>
            </article>

            <article class="legal-card">
              <h2>5. Cookies et stockage local</h2>
              <p>
                Le site ne dépose pas de cookie analytique interne pour la mesure d'audience.
                En revanche, votre choix de confidentialité est stocké localement dans votre navigateur.
              </p>
              <p class="note">
                <strong>Note :</strong> si vous ouvrez Google Maps ou Waze via un lien externe,
                vous quittez le site et les règles de confidentialité du service tiers s'appliquent.
              </p>
            </article>

            <article class="legal-card">
              <h2>6. Durée et droits</h2>
              <p>
                Les messages reçus sont conservés le temps nécessaire pour répondre à votre demande et assurer le suivi.
                Conformément au RGPD, vous pouvez demander l'accès, la rectification ou la suppression de vos données
                en écrivant à <strong class="gold">{clubInfo.email}</strong>.
              </p>
            </article>
          </div>
        </div>

        <div class="back-home">
          <a href="/" class="btn-back">
            <span class="arrow">←</span> Retour à l'accueil
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-section {
    padding: 180px 0 100px;
    background: var(--color-bg);
  }

  .container.narrow {
    max-width: 860px;
    margin: 0 auto;
  }

  .section-label {
    display: inline-flex;
    margin-bottom: 14px;
    color: var(--color-accent);
    font-family: var(--font-accent);
    font-size: 0.88rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .section-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: #fff;
    line-height: 1.05;
    margin-bottom: 38px;
  }

  .legal-content {
    color: #9b9b9b;
    line-height: 1.75;
  }

  .last-update {
    margin-bottom: 24px;
    font-size: 0.88rem;
    opacity: 0.7;
  }

  .intro {
    margin-bottom: 42px;
    color: #c7c7c7;
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .legal-grid {
    display: grid;
    gap: 24px;
  }

  .legal-card {
    padding: 22px 24px;
    border-left: 1px solid var(--color-accent);
    background: rgba(255, 255, 255, 0.02);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    border-right: 1px solid rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .legal-card h2 {
    margin-bottom: 12px;
    color: #fff;
    font-size: 1.55rem;
    font-family: var(--font-accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .legal-list {
    display: grid;
    gap: 12px;
    margin-top: 12px;
  }

  .legal-list li {
    position: relative;
    padding-left: 22px;
  }

  .legal-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .gold {
    color: var(--color-accent);
  }

  .note {
    margin-top: 16px;
    padding: 14px 16px;
    background: rgba(199, 157, 49, 0.06);
    border: 1px solid rgba(199, 157, 49, 0.12);
    color: #cfcfcf;
  }

  .back-home {
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-accent);
    font-family: var(--font-accent);
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .btn-back:hover {
    color: #fff;
  }

  .text-stroke {
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.4);
  }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 1s forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .legal-section {
      padding-top: 140px;
      padding-bottom: 74px;
    }

    .legal-card {
      padding: 18px;
    }

    .legal-card h2 {
      font-size: 1.3rem;
    }
  }
</style>
