---
import { clubInfo, resolveOptimizedPublicPath } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const staff = [
  {
    nom: "Mirac Colak",
    role: "Entraîneur principal",
    description:
      "Pilote la ligne technique du club et la préparation des compétiteurs.",
    image: resolveOptimizedPublicPath("/mirac.jpeg"),
    style: "object-position: center 14%;",
  },
  {
    nom: "Carmelo Pirrello",
    role: "Débutants et récréants",
    description:
      "Installe les bases, le cadre et la progression des nouveaux profils.",
    image: resolveOptimizedPublicPath("/carmelo.JPG"),
    style: "object-position: center 28%;",
  },
  {
    nom: "Ferhat Colak",
    role: "Coach / Soigneur",
    description:
      "Assure le suivi du coin, la récupération et l'accompagnement terrain.",
    image: resolveOptimizedPublicPath("/ferhat.jpeg"),
    style: "object-position: center top;",
  },
  {
    nom: "Massimo la Bella",
    role: "Coach adjoint / Soigneur",
    description:
      "Renforce le travail quotidien du staff et la vigilance autour des boxeurs.",
    image: resolveOptimizedPublicPath("/mass.jpeg"),
    style: "object-position: center 24%;",
  },
  {
    nom: "Pierre Gangai",
    role: "Nutritionniste",
    description:
      "Travaille la stratégie alimentaire au service de la performance et du poids.",
    image: resolveOptimizedPublicPath("/pierre.jpeg"),
    style: "object-position: center 14%;",
  },
];

const boxeursPro = [
  {
    nom: "Benito Muyayi",
    categorie: "Poids welters",
    palmares: "7-0-0 (4 KO)",
    image: resolveOptimizedPublicPath("/beni.jpeg"),
  },
  {
    nom: "Antonio D'Urbano",
    categorie: "Super-légers",
    palmares: "3-0-0",
    image: resolveOptimizedPublicPath("/toni.jpeg"),
  },
  {
    nom: "Oguz-han Yilmaz",
    categorie: "Mi-lourds",
    palmares: "1-0-1",
    image: resolveOptimizedPublicPath("/zugo.jpeg"),
  },
  {
    nom: "Yesna Kasin",
    categorie: "Super-mouches",
    palmares: "À venir",
    image: resolveOptimizedPublicPath("/yesna.jpeg"),
  },
];

const boxeursAmateurs = [
  { nom: "Jordan Moyonga", image: resolveOptimizedPublicPath("/jojo.jpeg") },
  { nom: "Kelson Impérial", image: resolveOptimizedPublicPath("/kelson.jpeg") },
  { nom: "Randy Konde", image: resolveOptimizedPublicPath("/randy.jpeg") },
  { nom: "Joël Adingara", image: resolveOptimizedPublicPath("/joel.jpeg") },
  { nom: "Murat Kulaksiz", image: resolveOptimizedPublicPath("/murat.jpeg") },
  { nom: "Anselme Kabala", image: resolveOptimizedPublicPath("/ace.jpeg") },
  { nom: "Aïssa Benmaamar", image: resolveOptimizedPublicPath("/aisa.jpeg") },
  { nom: "Yoan Kamkom", image: resolveOptimizedPublicPath("/yoan.jpeg") },
  { nom: "Massimo Alaimo", image: resolveOptimizedPublicPath("/massimo.jpeg") },
  { nom: "Carlo D'Aleo", image: resolveOptimizedPublicPath("/carlo.jpeg") },
  { nom: "Luigi Donzella", image: resolveOptimizedPublicPath("/marseille.jpeg") },
];

const clubPillars = [
  {
    title: "Discipline",
    text: "Une pratique cadrée, régulière et assumée.",
  },
  {
    title: "Transmission",
    text: "Des bases propres pour les débutants comme pour les confirmés.",
  },
  {
    title: "Vision",
    text: "Loisir sérieux, amateurs et compétition dans une même ligne.",
  },
];

const pageSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: `Le club | ${clubInfo.name}`,
  url: `${clubInfo.siteUrl}/club`,
  description:
    `Découvrez le staff, le roster et l'identité du ${clubInfo.name} à ${clubInfo.city}.`,
});
---

<BaseLayout
  title={`Le club et l'encadrement | ${clubInfo.name}`}
  description={`Découvrez le staff, le roster et l'identité du ${clubInfo.name}, club de boxe anglaise à ${clubInfo.city}.`}
  image="/mirac.jpeg"
  schema={pageSchema}
>
  <section class="club-hero">
    <div class="club-hero-bg">COLAK</div>

    <div class="container">
      <div class="club-hero-shell">
        <div class="club-hero-main">
          <span class="section-label">L'héritage</span>
          <h1 class="page-title">
            Le club, le cadre
            <br />
            <span class="text-stroke">et les visages</span>
          </h1>
          <p class="hero-lead">
            Le Boxing Club Colak défend une boxe anglaise structurée à {clubInfo.city}:
            du cadre, de la régularité et un encadrement présent.
          </p>

          <div class="hero-actions">
            <a href="/contact?sujet=essai" class="btn-main">Séance d'essai</a>
            <a href="#staff" class="btn-secondary-link">Voir le staff</a>
          </div>
        </div>

        <div class="club-hero-side">
          <div class="hero-fact">
            <span>Ville</span>
            <strong>{clubInfo.city}</strong>
          </div>
          <div class="hero-fact">
            <span>Staff</span>
            <strong>{staff.length} profils</strong>
          </div>
          <div class="hero-fact">
            <span>Roster</span>
            <strong>{boxeursPro.length + boxeursAmateurs.length} boxeurs</strong>
          </div>
        </div>
      </div>

      <div class="pillars-grid">
        {clubPillars.map((pillar) => (
          <article class="pillar-card reveal">
            <h2>{pillar.title}</h2>
            <p>{pillar.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-club story-section">
    <div class="container">
      <div class="story-grid">
        <div class="story-title">
          <span class="section-label">Identité</span>
          <h2 class="section-title">Une salle pensée pour progresser proprement</h2>
        </div>

        <div class="story-copy">
          <p>
            Le club accueille débutants, pratiquants loisir et compétiteurs dans un
            cadre clair, avec une attente simple: travailler sérieusement.
          </p>
          <p>
            Ici, l'objectif n'est pas de faire illusion. Il s'agit d'installer des bases,
            d'élever le niveau et de tenir une ligne cohérente dans le temps.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-club alt" id="staff">
    <div class="container">
      <div class="header-minimal">
        <h2 class="title-label">Le staff</h2>
        <div class="header-line"></div>
      </div>

      <div class="coaches-grid">
        {staff.map((membre) => (
          <article class="coach-card reveal">
            <div class="coach-image-wrapper">
              <img
                src={membre.image}
                alt={membre.nom}
                class="staff-img"
                style={membre.style}
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="coach-info">
              <span class="coach-role">{membre.role}</span>
              <h3>{membre.nom}</h3>
              <p>{membre.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-club">
    <div class="container">
      <div class="header-minimal">
        <h2 class="title-label">Section professionnelle</h2>
        <div class="header-line"></div>
      </div>

      <div class="pro-track">
        {boxeursPro.map((boxeur) => (
          <article class="pro-card reveal">
            <div class="pro-media">
              <img
                src={boxeur.image}
                alt={boxeur.nom}
                class="fighter-img"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="pro-info">
              <span class="pro-badge">Pro</span>
              <h3>{boxeur.nom}</h3>
              <p class="fighter-cat">{boxeur.categorie}</p>
              <p class="palmares">{boxeur.palmares}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-club roster-section">
    <div class="container">
      <div class="header-minimal">
        <h2 class="title-label">Section amateurs</h2>
        <div class="header-line"></div>
      </div>

      <div class="amateur-grid">
        {boxeursAmateurs.map((boxeur) => (
          <article class="amateur-card reveal">
            <div class="amateur-media">
              <img
                src={boxeur.image}
                alt={boxeur.nom}
                class="amateur-img"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="amateur-info">
              <h3>{boxeur.nom}</h3>
              <span>Amateur</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-club club-cta">
    <div class="container">
      <div class="cta-shell">
        <div>
          <span class="section-label">Rejoindre le club</span>
          <h2 class="section-title">Prêt à entrer dans le cadre ?</h2>
        </div>
        <div class="cta-actions">
          <a href="/contact?sujet=essai" class="btn-main">Réserver un essai</a>
          <a href="/contact" class="btn-secondary-link">Contacter le club</a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.documentElement.classList.add("reveal-ready");

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".reveal").forEach((element) => observer.observe(element));
  </script>

  <style>
    .section-club {
      padding: 96px 0;
    }

    .club-hero {
      position: relative;
      overflow: hidden;
      padding: 146px 0 82px;
    }

    .club-hero-bg {
      position: absolute;
      right: -4vw;
      top: 8vh;
      font-family: var(--font-accent);
      font-size: 20vw;
      line-height: 0.8;
      color: rgba(255, 255, 255, 0.03);
      pointer-events: none;
    }

    .club-hero-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(260px, 0.75fr);
      gap: 24px;
      padding: 36px;
      border: 1px solid rgba(199, 157, 49, 0.12);
      background:
        linear-gradient(135deg, rgba(199, 157, 49, 0.06), rgba(255, 255, 255, 0.015) 38%),
        rgba(0, 0, 0, 0.78);
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
      position: relative;
      z-index: 1;
    }

    .section-label {
      display: inline-flex;
      margin-bottom: 14px;
      color: var(--color-accent);
      font-family: var(--font-accent);
      font-size: 0.88rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .page-title,
    .section-title {
      font-size: clamp(2.8rem, 7vw, 5.8rem);
      color: #fff;
      line-height: 1;
      text-transform: uppercase;
    }

    .section-title {
      font-size: clamp(2rem, 4.5vw, 3.3rem);
    }

    .text-stroke {
      color: transparent;
      -webkit-text-stroke: 1px rgba(255, 255, 255, 0.4);
    }

    .hero-lead {
      max-width: 42rem;
      margin-top: 22px;
      color: #bdbdbd;
      font-size: clamp(1rem, 1.7vw, 1.15rem);
      line-height: 1.68;
    }

    .hero-actions,
    .cta-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 16px 22px;
      margin-top: 28px;
    }

    .btn-main {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 56px;
      padding: 0 28px;
      background: var(--color-accent);
      color: #050505;
      font-family: var(--font-accent);
      font-size: 1.08rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .btn-secondary-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 56px;
      color: #fff;
      font-family: var(--font-accent);
      font-size: 1rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-bottom: 1px solid var(--color-accent);
      padding-bottom: 4px;
    }

    .club-hero-side {
      display: grid;
      gap: 14px;
    }

    .hero-fact {
      padding: 18px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.025);
    }

    .hero-fact span {
      display: inline-flex;
      margin-bottom: 8px;
      color: var(--color-accent);
      font-family: var(--font-accent);
      font-size: 0.82rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .hero-fact strong {
      display: block;
      color: #fff;
      font-family: var(--font-accent);
      font-size: 1.45rem;
      line-height: 1.05;
      letter-spacing: 0.04em;
    }

    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 16px;
    }

    .pillar-card {
      padding: 20px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(255, 255, 255, 0.03);
    }

    .pillar-card h2 {
      margin-bottom: 8px;
      color: #fff;
      font-size: 1.3rem;
    }

    .pillar-card p {
      color: #9e9e9e;
      line-height: 1.55;
    }

    .story-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap: 36px;
      align-items: start;
    }

    .story-copy p {
      color: #b6b6b6;
      font-size: 1.04rem;
      line-height: 1.72;
    }

    .story-copy p + p {
      margin-top: 18px;
    }

    .alt {
      background: rgba(199, 157, 49, 0.03);
    }

    .header-minimal {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 34px;
    }

    .title-label {
      color: var(--color-accent);
      font-family: var(--font-accent);
      font-size: 1.05rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .header-line {
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, 0.06);
    }

    .coaches-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
    }

    .coach-card {
      display: flex;
      flex-direction: column;
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(255, 255, 255, 0.025);
      overflow: hidden;
    }

    .coach-image-wrapper {
      aspect-ratio: 4 / 5;
      background: #050505;
      overflow: hidden;
    }

    .staff-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transform: scale(1.02);
      transition: 0.45s ease;
    }

    .coach-card:hover .staff-img {
      transform: scale(1.05);
    }

    .coach-info {
      display: flex;
      flex-direction: column;
      justify-content: end;
      padding: 18px;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .coach-role {
      display: inline-flex;
      margin-bottom: 10px;
      color: var(--color-accent);
      font-family: var(--font-accent);
      font-size: 0.9rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .coach-info h3 {
      color: #fff;
      font-size: 1.9rem;
      margin-bottom: 10px;
    }

    .coach-info p {
      color: #9f9f9f;
      line-height: 1.58;
    }

    .pro-track {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(260px, 320px);
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 8px;
      scrollbar-width: thin;
      scrollbar-color: rgba(199, 157, 49, 0.5) rgba(255, 255, 255, 0.04);
    }

    .pro-card {
      border: 1px solid rgba(199, 157, 49, 0.16);
      background: rgba(255, 255, 255, 0.025);
      overflow: hidden;
      scroll-snap-align: start;
    }

    .pro-media {
      aspect-ratio: 4 / 5;
      background: #050505;
    }

    .fighter-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(0.4);
      transition: 0.45s ease;
    }

    .pro-card:hover .fighter-img,
    .amateur-card:hover .amateur-img {
      filter: grayscale(0);
      transform: scale(1.04);
    }

    .pro-info {
      padding: 18px;
    }

    .pro-badge {
      display: inline-flex;
      margin-bottom: 10px;
      padding: 6px 10px;
      background: var(--color-accent);
      color: #050505;
      font-family: var(--font-accent);
      font-size: 0.82rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .pro-info h3,
    .amateur-info h3 {
      color: #fff;
      font-size: 1.5rem;
      margin-bottom: 6px;
    }

    .fighter-cat {
      color: var(--color-accent);
      font-size: 0.9rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .palmares {
      margin-top: 10px;
      color: #c8c8c8;
    }

    .amateur-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }

    .amateur-card {
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(255, 255, 255, 0.025);
      overflow: hidden;
    }

    .amateur-media {
      aspect-ratio: 4 / 5;
      background: #050505;
      overflow: hidden;
    }

    .amateur-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(0.45);
      transition: 0.45s ease;
    }

    .amateur-info {
      padding: 14px;
    }

    .amateur-info span {
      color: var(--color-accent);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .club-cta {
      padding-top: 0;
    }

    .cta-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 20px;
      align-items: end;
      padding: 30px;
      border: 1px solid rgba(199, 157, 49, 0.14);
      background:
        linear-gradient(135deg, rgba(199, 157, 49, 0.06), rgba(255, 255, 255, 0.015) 38%),
        rgba(0, 0, 0, 0.72);
    }

    .reveal {
      opacity: 1;
      transform: none;
    }

    :global(html.reveal-ready) .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    :global(html.reveal-ready) .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (max-width: 1080px) {
      .club-hero-shell,
      .story-grid,
      .cta-shell {
        grid-template-columns: 1fr;
      }

      .amateur-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 820px) {
      .club-hero {
        padding-top: 122px;
      }

      .club-hero-shell {
        padding: 24px;
      }

      .club-hero-bg {
        display: none;
      }

      .coaches-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .pillars-grid {
        grid-template-columns: 1fr;
      }

      .amateur-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .section-club {
        padding: 74px 0;
      }

      .page-title {
        font-size: 3.6rem;
      }

      .hero-actions,
      .cta-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .btn-main,
      .btn-secondary-link {
        width: 100%;
      }

      .pro-track {
        grid-auto-columns: 84%;
      }

      .coaches-grid {
        grid-template-columns: 1fr;
      }

      .amateur-grid {
        grid-template-columns: 1fr;
      }

      .coach-info,
      .pro-info,
      .amateur-info,
      .pillar-card,
      .hero-fact,
      .hero-side-card,
      .cta-shell {
        padding: 18px;
      }

      .faq-item summary {
        font-size: 1.05rem;
      }
    }
  </style>
</BaseLayout>
