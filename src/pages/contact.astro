---
import MapPanel from "../components/MapPanel.astro";
import { clubInfo, contactSubjects } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const emailJsConfig = {
  publicKey:
    import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY ?? "mAR7_JuiRBmmhJtuq",
  serviceId:
    import.meta.env.PUBLIC_EMAILJS_SERVICE_ID ?? "service_yf1ji1g",
  templateId:
    import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID ?? "template_0clvoqw",
};

const contactSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: `Contact ${clubInfo.name}`,
  url: `${clubInfo.siteUrl}/contact`,
  description:
    "Page de contact du Boxing Club Colak à La Louvière pour les séances d'essai, inscriptions et demandes d'information.",
});
---

<BaseLayout 
  title={`Contact et inscription | ${clubInfo.name}`}
  description={`Contactez ${clubInfo.name}, club de boxe anglaise à ${clubInfo.city}, pour une séance d'essai, une inscription loisir ou un suivi compétiteur.`}
  image="/hero-boxe.jpg"
  schema={contactSchema}
>

<section class="contact-hero first">
  <div class="container reveal">
    <span class="section-label">Disponibilité & Écoute</span>
    <h1 class="page-title">ENTRER SUR <span class="text-stroke">LE RING</span></h1>
    <p class="hero-subtitle">Vous cherchez un club de boxe anglaise à La Louvière pour commencer, reprendre ou vous structurer ? Utilisez ce formulaire pour réserver une séance d'essai ou préparer votre inscription.</p>
  </div>
</section>

<section class="section-contact-main">
  <div class="container">
    <div class="contact-grid">
      
      <div class="contact-info-wrapper reveal">
        <div class="info-card">
          <h2 class="info-title">Nos coordonnées</h2>
          
          <div class="info-item">
            <span class="info-label">Adresse</span>
            <p>{clubInfo.addressFull}</p>
          </div>

          <div class="info-item">
            <span class="info-label">Téléphone</span>
            <p><a href={`tel:${clubInfo.phoneHref}`} class="link-gold">{clubInfo.phoneDisplay}</a></p>
          </div>

          <div class="info-item">
            <span class="info-label">E-mail</span>
            <p><a href={`mailto:${clubInfo.email}`} class="link-gold">{clubInfo.email}</a></p>
          </div>
        </div>

        <div class="social-card">
          <h2 class="info-title">Réseaux Sociaux</h2>
          <div class="social-links">
            {clubInfo.socialLinks.map((social) => (
              <a href={social.href} target="_blank" rel="noopener noreferrer" class="social-btn">
                {social.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="form-wrapper reveal">
        <form id="contact-form" class="contact-form">
          <div class="form-group-row">
            <div class="form-group">
              <label for="name">Nom complet</label>
              <input type="text" id="name" name="name" placeholder="Nom et prénom" autocomplete="name" required />
            </div>
            <div class="form-group">
              <label for="email">E-mail</label>
              <input type="email" id="email" name="email" placeholder="votre@email.com" autocomplete="email" required />
            </div>
          </div>

          <div class="form-group">
            <label for="subject">Sujet de votre demande</label>
            <select id="subject" name="subject">
              {contactSubjects.map(s => (
                <option value={s}>{s}</option>
              ))}
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" placeholder="Comment pouvons-nous vous aider ?" required></textarea>
          </div>

          <button type="submit" id="submit-btn" class="btn-submit">ENVOYER LE MESSAGE</button>
          <p id="form-status" class="form-status-msg" aria-live="polite"></p>
        </form>
      </div>
    </div>

    <div class="map-panel-wrapper reveal">
      <MapPanel
        title="Préparer votre venue au club"
        subtitle="Retrouvez l'adresse exacte, le contact direct et un itinéraire simple vers la salle. Cela rend la première venue plus fluide et renforce la cohérence locale du site."
        detailsTitle="Avant de venir"
      />
    </div>
  </div>
</section>

</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
<script is:inline define:vars={{ emailJsConfig }}>
  const contactForm = document.getElementById('contact-form');
  const subjectSelect = document.getElementById('subject');
  const submitBtn = document.getElementById('submit-btn');
  const statusMsg = document.getElementById('form-status');

  const sujetMap = {
    essai: "Séance d'essai gratuite",
    "fitness-femmes": "Cours boxe fitness femmes",
    novice: "Inscription (Novice / Loisir)",
    competiteur: "Inscription (Compétiteur)",
    question: "Question générale",
    partenariat: "Partenariat / Presse"
  };

  if (subjectSelect) {
    const preselected = sujetMap[new URLSearchParams(window.location.search).get('sujet')];
    if (preselected) subjectSelect.value = preselected;
  }

  if (contactForm && submitBtn && statusMsg) {
    if (window.emailjs && emailJsConfig.publicKey) {
      window.emailjs.init(emailJsConfig.publicKey);
    }

    contactForm.addEventListener('submit', function(event) {
      event.preventDefault();

      if (!window.emailjs || !emailJsConfig.serviceId || !emailJsConfig.templateId) {
        statusMsg.innerText = "Le service d'envoi est indisponible pour le moment.";
        statusMsg.style.color = "#ff4d4d";
        return;
      }

      submitBtn.innerText = "ENVOI EN COURS...";
      submitBtn.disabled = true;

      const formData = new FormData(contactForm);
      const templateParams = {
        name: String(formData.get('name') || '').trim(),
        email: String(formData.get('email') || '').trim(),
        subject: String(formData.get('subject') || '').trim(),
        message: String(formData.get('message') || '').trim(),
        reply_to: String(formData.get('email') || '').trim(),
      };

      window.emailjs.send(emailJsConfig.serviceId, emailJsConfig.templateId, templateParams)
        .then(() => {
          statusMsg.innerText = "Message envoyé avec succès ! Le coach vous répondra bientôt.";
          statusMsg.style.color = "#c79d31";
          contactForm.reset();
          submitBtn.innerText = "ENVOYER LE MESSAGE";
          submitBtn.disabled = false;
        }, () => {
          statusMsg.innerText = "Erreur lors de l'envoi. Veuillez réessayer plus tard.";
          statusMsg.style.color = "#ff4d4d";
          submitBtn.innerText = "RÉESSAYER";
          submitBtn.disabled = false;
        });
    });
  }

  // Animation Reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if(entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
  /* CONFIGURATION GÉNÉRALE */
  .contact-hero { padding: 154px 0 72px; text-align: left; }
  
  .section-label {
    display: block;
    font-family: var(--font-accent);
    color: var(--color-accent);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 15px;
    font-size: 0.9rem;
  }

  .page-title {
    font-size: clamp(3rem, 8vw, 6rem);
    color: #fff;
    text-transform: uppercase;
    margin-bottom: 30px;
    line-height: 1;
  }

  .text-stroke {
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.4);
  }

  .hero-subtitle { 
    max-width: 760px; 
    font-size: 1.14rem; 
    color: #888; 
    line-height: 1.58;
  }

  .section-contact-main { padding-bottom: 82px; }
  .contact-grid { 
    display: grid; 
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr); 
    gap: 48px; 
    align-items: flex-start;
  }

  /* INFOS & CARDS */
  .info-card, .social-card { 
    background: rgba(255, 255, 255, 0.02); 
    border: 1px solid rgba(255, 255, 255, 0.05); 
    padding: 36px; 
    margin-bottom: 30px; 
  }

  .info-title { 
    font-family: var(--font-accent); 
    color: #fff; 
    text-transform: uppercase; 
    font-size: 1.5rem; 
    margin-bottom: 40px; 
    letter-spacing: 2px; 
  }

  .info-item { margin-bottom: 30px; }
  .info-label { 
    display: block; 
    font-size: 0.7rem; 
    text-transform: uppercase; 
    color: var(--color-accent); 
    letter-spacing: 3px; 
    margin-bottom: 10px; 
  }
  .info-item p { font-size: 1.2rem; color: #fff; }

  .link-gold { color: #fff; text-decoration: none; transition: 0.3s; font-weight: 700; }
  .link-gold:hover { color: var(--color-accent); }

  .social-links { display: flex; gap: 15px; flex-wrap: wrap; }
  .social-btn { 
    padding: 10px 20px; 
    border: 1px solid rgba(255,255,255,0.1); 
    color: #888; 
    text-decoration: none; 
    font-size: 0.8rem; 
    font-family: var(--font-accent);
    letter-spacing: 1px;
    transition: 0.3s; 
  }
  .social-btn:hover { background: var(--color-accent); color: #000; border-color: var(--color-accent); }

  /* FORMULAIRE - AGRANDI POUR MOBILE */
  .form-wrapper { 
    background: rgba(199, 157, 49, 0.03); 
    border: 1px solid rgba(199, 157, 49, 0.1); 
    padding: 38px; 
  }
  .contact-form { display: flex; flex-direction: column; gap: 30px; }
  .form-group-row { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
  .form-group { display: flex; flex-direction: column; gap: 12px; }
  .form-group label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; color: #666; font-family: var(--font-accent); }
  
  input, select, textarea { 
    background: #000; 
    border: 1px solid rgba(255,255,255,0.1); 
    padding: 18px; 
    color: #fff; 
    font-size: 1rem;
    transition: 0.3s; 
  }
  input:focus, select:focus, textarea:focus { 
    outline: none; 
    border-color: var(--color-accent); 
    background: rgba(199, 157, 49, 0.05); 
  }

  .btn-submit { 
    background: var(--color-accent); 
    color: #000; 
    padding: 22px; 
    border: none; 
    font-family: var(--font-accent);
    font-size: 1.2rem;
    letter-spacing: 2px;
    cursor: pointer; 
    transition: 0.3s; 
    margin-top: 10px;
  }
  .btn-submit:hover { background: #fff; transform: translateY(-3px); }
  
  .form-status-msg { margin-top: 20px; font-size: 1rem; font-weight: 500; text-align: center; }

  /* MAP */
  .map-panel-wrapper { margin-top: 56px; }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr; gap: 32px; }
  }

  @media (max-width: 768px) {
    .contact-hero { padding: 132px 0 58px; }
    .hero-subtitle { font-size: 1.02rem; }
    .section-contact-main { padding-bottom: 68px; }
    .form-wrapper { padding: 26px 18px; }
    .form-group-row { grid-template-columns: 1fr; gap: 24px; }
    .info-card, .social-card { padding: 24px 18px; }
  }

  /* REVEAL ANIMATION */
  .reveal { opacity: 0; transform: translateY(30px); transition: 1s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>
